#:import dp kivy.metrics.dp
#:import sp kivy.metrics.sp
#:import theme game.theme
#:import ScrollEffect kivy.effects.scroll.ScrollEffect

<LoreScreen>:
    BoxLayout:
        orientation: "vertical"
        canvas.before:
            Color:
                rgba: app.bg_dark
            Rectangle:
                pos: self.pos
                size: self.size

        # Top bar
        TopBar:
            title_text: app.title_lore
            title_color: app.accent_purple

        TouchPanel:
            size_hint_y: None
            height: dp(48)
            spacing: dp(4)
            padding: [dp(8), dp(2)]
            MinimalButton:
                text: app.lbl_achievements
                btn_color: theme.ACCENT_GOLD if root.lore_tab == "achievements" else theme.BTN_DISABLED
                text_color: theme.TEXT_PRIMARY if root.lore_tab == "achievements" else theme.TEXT_MUTED
                font_size: 11
                on_press: root.set_lore_tab("achievements")
            MinimalButton:
                text: app.lbl_diamond_shop
                btn_color: theme.ACCENT_CYAN if root.lore_tab == "shop" else theme.BTN_DISABLED
                text_color: theme.TEXT_PRIMARY if root.lore_tab == "shop" else theme.TEXT_MUTED
                font_size: 11
                on_press: root.set_lore_tab("shop")
            MinimalButton:
                text: app.lbl_quests
                btn_color: theme.ACCENT_GOLD if root.lore_tab == "quests" else theme.BTN_DISABLED
                text_color: theme.TEXT_PRIMARY if root.lore_tab == "quests" else theme.TEXT_MUTED
                font_size: 11
                on_press: root.set_lore_tab("quests")
            MinimalButton:
                text: app.lbl_stats
                btn_color: theme.ACCENT_GREEN if root.lore_tab == "stats" else theme.BTN_DISABLED
                text_color: theme.TEXT_PRIMARY if root.lore_tab == "stats" else theme.TEXT_MUTED
                font_size: 11
                on_press: root.set_lore_tab("stats")

        # Battle log subview — RecycleView (up to 200 entries)
        TouchRecycleView:
            id: battle_log_rv
            viewclass: 'BattleLogCardView'
            bar_width: dp(8)
            bar_color: app.text_muted
            do_scroll_x: False
            scroll_type: ['bars', 'content']
            effect_cls: ScrollEffect
            scroll_distance: dp(8)
            scroll_timeout: 50
            size_hint_y: 1 if root.lore_subview == 'blog_list' else 0.001
            opacity: 1 if root.lore_subview == 'blog_list' else 0
            disabled: root.lore_subview != 'blog_list'
            RecycleBoxLayout:
                default_size: None, dp(78)
                default_size_hint: 1, None
                size_hint_y: None
                height: self.minimum_height
                orientation: 'vertical'
                spacing: dp(4)
                padding: [dp(14), dp(8)]

        # Battle DETAIL subview — virtualized line log (can be 10000+ lines
        # for 1000-vs-1000 battles, plain widgets were taking seconds to build)
        TouchRecycleView:
            id: battle_detail_rv
            viewclass: 'BattleDetailLineView'
            bar_width: dp(8)
            bar_color: app.text_muted
            do_scroll_x: False
            scroll_type: ['bars', 'content']
            effect_cls: ScrollEffect
            scroll_distance: dp(8)
            scroll_timeout: 50
            size_hint_y: 1 if root.lore_subview in ('blog_detail', 'event_detail') else 0.001
            opacity: 1 if root.lore_subview in ('blog_detail', 'event_detail') else 0
            disabled: root.lore_subview not in ('blog_detail', 'event_detail')
            RecycleBoxLayout:
                default_size: None, dp(18)
                default_size_hint: 1, None
                size_hint_y: None
                height: self.minimum_height
                orientation: 'vertical'
                spacing: dp(1)
                padding: [dp(14), dp(8)]

        # Event log subview — RecycleView (up to 200 entries)
        TouchRecycleView:
            id: event_log_rv
            viewclass: 'EventLogCardView'
            bar_width: dp(8)
            bar_color: app.text_muted
            do_scroll_x: False
            scroll_type: ['bars', 'content']
            effect_cls: ScrollEffect
            scroll_distance: dp(8)
            scroll_timeout: 50
            size_hint_y: 1 if root.lore_subview == 'event_list' else 0.001
            opacity: 1 if root.lore_subview == 'event_list' else 0
            disabled: root.lore_subview != 'event_list'
            RecycleBoxLayout:
                default_size: None, dp(48)
                default_size_hint: 1, None
                size_hint_y: None
                height: self.minimum_height
                orientation: 'vertical'
                spacing: dp(4)
                padding: [dp(14), dp(8)]

        # Achievements tab — RecycleView (50 items virtualized)
        TouchRecycleView:
            id: achievements_rv
            viewclass: 'AchievementCardView'
            bar_width: dp(8)
            bar_color: app.text_muted
            do_scroll_x: False
            scroll_type: ['bars', 'content']
            effect_cls: ScrollEffect
            scroll_distance: dp(8)
            scroll_timeout: 50
            size_hint_y: 1 if (root.lore_tab == 'achievements' and not root.lore_subview) else 0.001
            opacity: 1 if (root.lore_tab == 'achievements' and not root.lore_subview) else 0
            disabled: not (root.lore_tab == 'achievements' and not root.lore_subview)
            RecycleBoxLayout:
                default_size: None, dp(75)
                default_size_hint: 1, None
                size_hint_y: None
                height: self.minimum_height
                orientation: 'vertical'
                spacing: dp(4)
                padding: [dp(14), dp(8)]

        # Other lore tabs (shop / quests / stats) + subview — legacy GridLayout
        TouchScrollView:
            bar_width: dp(8)
            bar_color: app.text_muted
            do_scroll_x: False
            scroll_type: ['bars', 'content']
            effect_cls: ScrollEffect
            scroll_distance: dp(8)
            scroll_timeout: 50
            size_hint_y: 0.001 if (root.lore_subview in ('blog_list', 'blog_detail', 'event_list', 'event_detail') or (root.lore_tab == 'achievements' and not root.lore_subview)) else 1
            opacity: 0 if (root.lore_subview in ('blog_list', 'blog_detail', 'event_list', 'event_detail') or (root.lore_tab == 'achievements' and not root.lore_subview)) else 1
            disabled: root.lore_subview in ('blog_list', 'blog_detail', 'event_list', 'event_detail') or (root.lore_tab == 'achievements' and not root.lore_subview)
            GridLayout:
                id: lore_grid
                cols: 1
                spacing: dp(4)
                padding: [dp(14), dp(8)]
                size_hint_y: None
                height: self.minimum_height

        MinimalButton:
            id: lore_back_btn
            text: app.lbl_back_btn
            btn_color: theme.BTN_PRIMARY
            font_size: 11
            size_hint_y: None
            height: dp(48) if root.lore_subview else 0
            opacity: 1 if root.lore_subview else 0
            disabled: not root.lore_subview
            on_press: app.go_back()

        # Bottom buttons — fixed at bottom, only on stats tab
        BoxLayout:
            size_hint_y: None
            height: dp(52) if root.lore_tab == "stats" and not root.lore_subview else 0
            opacity: 1 if root.lore_tab == "stats" and not root.lore_subview else 0
            padding: [dp(8), dp(2)]
            spacing: dp(4)
            MinimalButton:
                text: root.battle_log_count or ""
                btn_color: theme.ACCENT_CYAN
                text_color: theme.BG_DARK
                font_size: 11
                on_press: root._show_battle_log()
            MinimalButton:
                text: root.event_log_count or ""
                btn_color: theme.ACCENT_GOLD
                text_color: theme.BG_DARK
                font_size: 11
                on_press: root._show_event_log()
# ============================================================
#  MORE (Settings)
# ============================================================
