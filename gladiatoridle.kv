                font_size: 10
                on_press: app.root.current = "lore"
            MinimalButton:
                text: "MORE"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 10
                on_press: app.root.current = "more"


# ============================================================
#  EXPEDITIONS (HUNTS)
# ============================================================
<ExpeditionScreen>:
    BoxLayout:
        orientation: "vertical"
        canvas.before:
            Color:
                rgba: app.bg_dark
            Rectangle:
                pos: self.pos
                size: self.size

        BoxLayout:
            size_hint_y: 0.055
            padding: [12, 3]
            canvas.before:
                Color:
                    rgba: app.nav_bg
                Rectangle:
                    pos: self.pos
                    size: self.size
            Label:
                text: "H U N T S"
                font_size: "12sp"
                color: app.accent_purple
                halign: "left"
                text_size: self.size
                valign: "middle"
            Label:
                text: root.gold_text
                font_size: "16sp"
                bold: True
                color: app.accent_gold
                halign: "right"
