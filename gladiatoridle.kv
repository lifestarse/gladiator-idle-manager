# ============================================================
#  SHOP (MARKET)
# ============================================================
<ShopScreen>:
    BoxLayout:
        orientation: "vertical"
        canvas.before:
            Color:
                rgba: app.bg_dark
            Rectangle:
                pos: self.pos
                size: self.size

        BoxLayout:
            size_hint_y: 0.055
            padding: [12, 3]
            canvas.before:
                Color:
                    rgba: app.nav_bg
                Rectangle:
                    pos: self.pos
                    size: self.size
            Label:
                text: "M A R K E T"
                font_size: "12sp"
                color: app.accent_blue
                halign: "left"
                text_size: self.size
                valign: "middle"
            Label:
                text: root.gold_text
                font_size: "16sp"
                bold: True
                color: app.accent_gold
                halign: "right"
                text_size: self.size
                valign: "middle"

        Label:
            text: root.idle_rate_text
            font_size: "11sp"
            color: app.accent_green
            size_hint_y: 0.03

        ScrollView:
            bar_width: 2
            bar_color: app.text_muted
            GridLayout:
                id: shop_grid
                cols: 1
                spacing: 6
                padding: [10, 6]
                size_hint_y: None
                height: self.minimum_height

        NavBar:
            MinimalButton:
                text: "PIT"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 10
                on_press: app.root.current = "arena"
            MinimalButton:
                text: "SQUAD"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 10
                on_press: app.root.current = "roster"
            MinimalButton:
                text: "ANVIL"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 10
                on_press: app.root.current = "forge"
            MinimalButton:
                text: "HUNTS"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 10
                on_press: app.root.current = "expedition"
            MinimalButton:
                text: "MRKT"
                btn_color: 0, 0, 0, 0
                text_color: app.accent_gold
                font_size: 10
            MinimalButton:
                text: "GEAR"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 10
                on_press: app.root.current = "settings"


# ============================================================
#  SETTINGS (GEAR)
# ============================================================
<SettingsScreen>:
    BoxLayout:
        orientation: "vertical"
        canvas.before:
            Color:
                rgba: app.bg_dark
            Rectangle:
                pos: self.pos
                size: self.size

        BoxLayout:
            size_hint_y: 0.055
            padding: [12, 3]
            canvas.before:
                Color:
                    rgba: app.nav_bg
                Rectangle:
                    pos: self.pos
                    size: self.size
            Label:
                text: "S E T T I N G S"
                font_size: "12sp"
                color: app.text_primary
                halign: "left"
                text_size: self.size
                valign: "middle"

        ScrollView:
            size_hint_y: 0.825
            bar_width: 2
            GridLayout:
                cols: 1
                spacing: 10
                padding: [16, 12]
                size_hint_y: None
                height: self.minimum_height

                # --- IAP Section ---
                Label:
                    text: "PREMIUM"
                    font_size: "11sp"
                    color: app.accent_gold
                    halign: "left"
                    text_size: self.width, None
                    size_hint_y: None
                    height: 25

                # Remove Ads
                BoxLayout:
                    size_hint_y: None
                    height: 55
                    spacing: 10
                    BoxLayout:
                        orientation: "vertical"
                        Label:
                            text: "Remove Ads"
                            font_size: "13sp"
                            bold: True
                            color: app.text_primary
                            halign: "left"
                            text_size: self.size
                        Label:
                            text: "Status: " + root.ads_status
                            font_size: "10sp"
                            color: app.text_muted
                            halign: "left"
                            text_size: self.size
                    MinimalButton:
                        text: "100 UAH"
                        btn_color: app.accent_gold
                        text_color: app.bg_dark
                        font_size: 12
                        size_hint_x: 0.35
                        on_press: root.buy_remove_ads()

                # VIP Idle
                BoxLayout:
                    size_hint_y: None
                    height: 55
                    spacing: 10
                    BoxLayout:
                        orientation: "vertical"
                        Label:
                            text: "VIP: 1.5x Income"
                            font_size: "13sp"
                            bold: True
                            color: app.text_primary
                            halign: "left"
                            text_size: self.size
                        Label:
                            text: "Status: " + root.vip_status
                            font_size: "10sp"
                            color: app.text_muted
                            halign: "left"
                            text_size: self.size
                    MinimalButton:
                        text: "100 UAH"
                        btn_color: app.accent_gold
                        text_color: app.bg_dark
                        font_size: 12
                        size_hint_x: 0.35
                        on_press: root.buy_vip_idle()

                # Restore
                MinimalButton:
                    text: "RESTORE PURCHASES"
                    btn_color: app.bg_elevated
                    text_color: app.text_secondary
                    font_size: 11
                    size_hint_y: None
                    height: 40
                    on_press: root.restore_purchases()

                # --- Cloud Save Section ---
                Label:
                    text: "CLOUD SAVE"
                    font_size: "11sp"
                    color: app.accent_cyan
                    halign: "left"
                    text_size: self.width, None
                    size_hint_y: None
                    height: 30

                Label:
                    text: root.cloud_status
                    font_size: "11sp"
                    color: app.text_secondary
                    halign: "center"
                    text_size: self.width, None
                    size_hint_y: None
                    height: 20

                MinimalButton:
                    text: "SIGN IN WITH GOOGLE"
                    btn_color: app.accent_blue
                    font_size: 12
                    size_hint_y: None
                    height: 42
                    on_press: root.cloud_sign_in()

                BoxLayout:
                    size_hint_y: None
                    height: 42
                    spacing: 8
                    MinimalButton:
                        text: "UPLOAD"
                        btn_color: app.accent_green
                        text_color: app.bg_dark
                        font_size: 11
                        on_press: root.cloud_upload()
                    MinimalButton:
                        text: "DOWNLOAD"
                        btn_color: app.accent_purple
                        font_size: 11
                        on_press: root.cloud_download()
                    MinimalButton:
                        text: "SYNC"
                        btn_color: app.accent_cyan
                        text_color: app.bg_dark
                        font_size: 11
                        on_press: root.cloud_sync()

        NavBar:
            MinimalButton:
                text: "PIT"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 10
                on_press: app.root.current = "arena"
            MinimalButton:
                text: "SQUAD"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 10
                on_press: app.root.current = "roster"
            MinimalButton:
                text: "ANVIL"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 10
                on_press: app.root.current = "forge"
            MinimalButton:
                text: "HUNTS"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 10
                on_press: app.root.current = "expedition"
            MinimalButton:
                text: "MRKT"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 10
                on_press: app.root.current = "shop"
            MinimalButton:
                text: "GEAR"
                btn_color: 0, 0, 0, 0
                text_color: app.accent_gold
                font_size: 10
