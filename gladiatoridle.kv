            text_size: self.width - 24, None
            halign: "center"
            padding: [12, 0]

        ScrollView:
            size_hint_y: 0.77
            bar_width: 2
            bar_color: app.text_muted
            GridLayout:
                id: forge_grid
                cols: 1
                spacing: 8
                padding: [12, 8]
                size_hint_y: None
