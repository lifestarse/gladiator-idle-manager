        NavBar:
            MinimalButton:
                text: "PIT"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 11
                on_press: app.root.current = "arena"
            MinimalButton:
                text: "SQUAD"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 11
                on_press: app.root.current = "roster"
            MinimalButton:
                text: "ANVIL"
                btn_color: 0, 0, 0, 0
                text_color: app.accent_gold
                font_size: 11
            MinimalButton:
                text: "HUNTS"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 11
                on_press: app.root.current = "expedition"
            MinimalButton:
                text: "MARKET"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 11
                on_press: app.root.current = "shop"


# ============================================================
#  EXPEDITIONS (HUNTS)
# ============================================================
<ExpeditionScreen>:
    BoxLayout:
        orientation: "vertical"
        canvas.before:
            Color:
                rgba: app.bg_dark
            Rectangle:
                pos: self.pos
                size: self.size

        # Top bar
        BoxLayout:
            size_hint_y: 0.06
            padding: [15, 4]
            canvas.before:
                Color:
                    rgba: app.nav_bg
                Rectangle:
                    pos: self.pos
                    size: self.size
            Label:
                text: "H U N T S"
                font_size: "13sp"
                color: app.accent_purple
                halign: "left"
                text_size: self.size
                valign: "middle"
            Label:
                text: root.gold_text
                font_size: "17sp"
                bold: True
                color: app.accent_gold
                halign: "right"
                text_size: self.size
                valign: "middle"

        # Active expeditions
        GridLayout:
            id: expedition_status_grid
            cols: 1
            spacing: 4
            padding: [12, 4]
            size_hint_y: None
            height: self.minimum_height

        # Expedition log
        Label:
            text: root.log_text
            font_size: "9sp"
            color: app.text_muted
            size_hint_y: 0.08
            text_size: self.width - 24, None
            halign: "center"
            valign: "middle"

        # Available expeditions
        ScrollView:
            bar_width: 2
            bar_color: app.text_muted
            GridLayout:
                id: expedition_grid
                cols: 1
                spacing: 8
                padding: [12, 8]
                size_hint_y: None
                height: self.minimum_height

        NavBar:
            MinimalButton:
                text: "PIT"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 11
                on_press: app.root.current = "arena"
            MinimalButton:
                text: "SQUAD"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 11
                on_press: app.root.current = "roster"
            MinimalButton:
                text: "ANVIL"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 11
                on_press: app.root.current = "forge"
            MinimalButton:
                text: "HUNTS"
                btn_color: 0, 0, 0, 0
                text_color: app.accent_gold
                font_size: 11
            MinimalButton:
                text: "MARKET"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 11
                on_press: app.root.current = "shop"


