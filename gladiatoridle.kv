        ScrollView:
            bar_width: 2
            bar_color: app.text_muted
            do_scroll_x: False
            scroll_distance: dp(8)
            scroll_timeout: 50
            GridLayout:
                id: expedition_grid
                cols: 1
                spacing: 6
                padding: [10, 6]
                size_hint_y: None
                height: self.minimum_height

        NavBar:
            NavButton:
                text: app.nav_pit
                icon_source: "icons/ic_four_star.png"
                is_active: False
                on_press: app.root.current = "arena"
            NavButton:
                text: app.nav_squad
                icon_source: "icons/ic_squad.png"
                is_active: False
                on_press: app.root.current = "roster"
            NavButton:
                text: app.nav_anvil
                icon_source: "icons/ic_anvil.png"
                is_active: False
                on_press: app.root.current = "forge"
            NavButton:
                text: app.nav_hunts
                icon_source: "icons/ic_hunts.png"
                is_active: True
            NavButton:
                text: app.nav_lore
                icon_source: "icons/ic_lore.png"
                is_active: False
                on_press: app.root.current = "lore"
            NavButton:
                text: app.nav_more
                icon_source: "icons/ic_more.png"
                is_active: False
                on_press: app.root.current = "more"
# ============================================================
#  LORE (Story + Achievements + Diamond Shop)
# ============================================================
<LoreScreen>:
    BoxLayout:
        orientation: "vertical"
        canvas.before:
            Color:
                rgba: app.bg_dark
            Rectangle:
                pos: self.pos
                size: self.size

        # Top bar
        TopBar:
            Label:
                text: app.title_lore
                font_size: "17sp"
                color: app.accent_purple
                halign: "left"
                text_size: self.size
                valign: "middle"
                size_hint_x: 0.4
            Label:
                text: root.diamond_text
                font_size: "17sp"
                bold: True
                color: app.accent_cyan
                halign: "right"
                text_size: self.size
                valign: "middle"
            Image:
                source: "icons/ic_gem.png"
                fit_mode: "contain"
                size_hint: None, 1
                width: dp(24)

        ScrollView:
            bar_width: 2
            bar_color: app.text_muted
            do_scroll_x: False
            scroll_distance: dp(8)
            scroll_timeout: 50
            GridLayout:
                cols: 1
                spacing: 8
                padding: [10, 8]
                size_hint_y: None
                height: self.minimum_height

                # --- Achievements section ---
                Label:
                    text: app.lbl_achievements
                    font_size: "21sp"
                    color: app.accent_gold
                    halign: "left"
                    text_size: self.width, None
                    size_hint_y: None
                    height: dp(30)

                GridLayout:
                    id: achievement_grid
                    cols: 1
                    spacing: 4
                    size_hint_y: None
                    height: self.minimum_height

                # --- Divider ---
                Widget:
                    size_hint_y: None
                    height: 1
                    canvas:
                        Color:
                            rgba: app.divider
                        Rectangle:
                            pos: self.pos
                            size: self.size

                # --- Diamond Shop section ---
                Label:
                    text: app.lbl_diamond_shop
                    font_size: "21sp"
                    color: app.accent_cyan
                    halign: "left"
                    text_size: self.width, None
                    size_hint_y: None
                    height: dp(30)

                GridLayout:
                    id: diamond_shop_grid
                    cols: 1
                    spacing: 4
                    size_hint_y: None
                    height: self.minimum_height

        NavBar:
            NavButton:
                text: app.nav_pit
                icon_source: "icons/ic_four_star.png"
                is_active: False
                on_press: app.root.current = "arena"
            NavButton:
                text: app.nav_squad
                icon_source: "icons/ic_squad.png"
                is_active: False
                on_press: app.root.current = "roster"
            NavButton:
                text: app.nav_anvil
                icon_source: "icons/ic_anvil.png"
                is_active: False
                on_press: app.root.current = "forge"
            NavButton:
                text: app.nav_hunts
                icon_source: "icons/ic_hunts.png"
                is_active: False
                on_press: app.root.current = "expedition"
            NavButton:
                text: app.nav_lore
                icon_source: "icons/ic_lore.png"
                is_active: True
            NavButton:
                text: app.nav_more
                icon_source: "icons/ic_more.png"
                is_active: False
                on_press: app.root.current = "more"
# ============================================================
#  MORE (Settings)
# ============================================================
<MoreScreen>:
    BoxLayout:
        orientation: "vertical"
        canvas.before:
            Color:
                rgba: app.bg_dark
            Rectangle:
                pos: self.pos
                size: self.size

        TopBar:
            Label:
                text: app.title_more
                font_size: "17sp"
                color: app.accent_blue
                halign: "left"
                text_size: self.size
                valign: "middle"
                size_hint_x: 0.4
            Label:
                text: root.gold_text
                font_size: "17sp"
                bold: True
                color: app.accent_gold
                halign: "right"
                text_size: self.size
                valign: "middle"
            Image:
                source: "icons/ic_gold.png"
                fit_mode: "contain"
                size_hint: None, 1
                width: dp(24)

        ScrollView:
            bar_width: 2
            bar_color: app.text_muted
            do_scroll_x: False
            scroll_distance: dp(8)
            scroll_timeout: 50
            GridLayout:
                cols: 1
                spacing: 8
                padding: [10, 8]
                size_hint_y: None
                height: self.minimum_height

                # --- Remove Ads ---
                BoxLayout:
                    id: ads_box
                    size_hint_y: None
                    height: dp(60)
                    spacing: 10
                    BoxLayout:
                        orientation: "vertical"
                        Label:
                            text: app.lbl_remove_ads
                            font_size: "18sp"
                            bold: True
                            color: app.text_primary
                            halign: "left"
                            text_size: self.size
                        Label:
                            text: root.ads_status
                            font_size: "20sp"
                            color: app.text_muted
                            halign: "left"
                            text_size: self.size
                    MinimalButton:
                        id: ads_buy_btn
                        text: app.lbl_remove_ads_buy
                        btn_color: app.accent_gold
                        text_color: app.bg_dark
                        font_size: "17sp"
                        size_hint_x: 0.35
                        on_press: root.buy_remove_ads()

                MinimalButton:
                    text: app.lbl_restore_purchases
                    btn_color: app.bg_elevated
                    text_color: app.text_secondary
                    font_size: "16sp"
                    size_hint_y: None
                    height: dp(44)
                    on_press: root.restore_purchases()

                # --- Divider ---
                Widget:
                    size_hint_y: None
                    height: 1
                    canvas:
                        Color:
                            rgba: app.divider
                        Rectangle:
                            pos: self.pos
                            size: self.size

                # --- Cloud Save ---
                Label:
                    text: app.lbl_cloud_save
                    font_size: "21sp"
                    color: app.accent_cyan
                    halign: "left"
                    text_size: self.width, None
                    size_hint_y: None
                    height: dp(30)

                Label:
                    text: root.cloud_status
                    font_size: "15sp"
                    color: app.text_secondary
                    halign: "center"
                    text_size: self.width, None
                    size_hint_y: None
                    height: dp(22)

                MinimalButton:
                    text: root.google_btn_text if root.google_btn_text else app.lbl_sign_in_google
                    btn_color: app.accent_green if root.google_signed_in else app.accent_blue
                    font_size: "14sp" if root.google_signed_in else "17sp"
                    size_hint_y: None
                    height: dp(46)
                    on_press: root.cloud_sign_in()

                MinimalButton:
                    text: app.lbl_sign_out_google
                    btn_color: app.accent_red
                    font_size: "15sp"
                    size_hint_y: None
                    height: dp(40) if root.google_signed_in else 0
                    opacity: 1 if root.google_signed_in else 0
                    disabled: not root.google_signed_in
                    on_press: root.cloud_sign_out()

                MinimalButton:
                    text: app.lbl_save_to_cloud
                    btn_color: app.accent_green
                    text_color: app.bg_dark
                    font_size: "16sp"
                    size_hint_y: None
                    height: dp(46) if root.google_signed_in else 0
                    opacity: 1 if root.google_signed_in else 0
                    disabled: not root.google_signed_in
                    on_press: root.cloud_upload()

                MinimalButton:
                    text: app.lbl_load_from_cloud
                    btn_color: app.accent_purple
                    font_size: "16sp"
                    size_hint_y: None
                    height: dp(46) if root.google_signed_in else 0
                    opacity: 1 if root.google_signed_in else 0
                    disabled: not root.google_signed_in
                    on_press: root.cloud_download()

                # --- Divider ---
                Widget:
                    size_hint_y: None
                    height: 1
                    canvas:
                        Color:
                            rgba: app.divider
                        Rectangle:
                            pos: self.pos
                            size: self.size

                # -- LEADERBOARD --
                Label:
                    text: app.lbl_leaderboard
                    font_size: "21sp"
                    color: app.accent_gold
                    halign: "left"
                    text_size: self.width, None
                    size_hint_y: None
                    height: dp(30)

                MinimalButton:
                    size_hint_y: None
                    height: dp(46)
                    text: app.lbl_view_leaderboard
                    btn_color: app.accent_gold
                    text_color: app.bg_dark
                    font_size: "16sp"
                    on_press: root.show_leaderboard()

                # --- Divider ---
                Widget:
                    size_hint_y: None
                    height: 1
                    canvas:
                        Color:
                            rgba: app.divider
                        Rectangle:
                            pos: self.pos
                            size: self.size

                # --- Language ---
                Label:
                    text: app.lbl_language
                    font_size: "21sp"
                    color: app.accent_cyan
                    halign: "left"
                    text_size: self.width, None
                    size_hint_y: None
                    height: dp(30)

                MinimalButton:
                    size_hint_y: None
                    height: dp(46)
                    text: app.lbl_change_language
                    btn_color: app.accent_purple
                    font_size: "16sp"
                    on_press: root.show_language_picker()

        NavBar:
            NavButton:
                text: app.nav_pit
                icon_source: "icons/ic_four_star.png"
                is_active: False
                on_press: app.root.current = "arena"
            NavButton:
                text: app.nav_squad
                icon_source: "icons/ic_squad.png"
                is_active: False
                on_press: app.root.current = "roster"
            NavButton:
                text: app.nav_anvil
                icon_source: "icons/ic_anvil.png"
                is_active: False
                on_press: app.root.current = "forge"
            NavButton:
                text: app.nav_hunts
                icon_source: "icons/ic_hunts.png"
                is_active: False
                on_press: app.root.current = "expedition"
            NavButton:
                text: app.nav_lore
                icon_source: "icons/ic_lore.png"
                is_active: False
                on_press: app.root.current = "lore"
            NavButton:
                text: app.nav_more
                icon_source: "icons/ic_more.png"
                is_active: True