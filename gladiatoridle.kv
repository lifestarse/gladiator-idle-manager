#:kivy 2.0
#:import theme game.theme
#:import MinimalBar game.widgets.MinimalBar
#:import GladiatorAvatar game.widgets.GladiatorAvatar
#:import MinimalButton game.widgets.MinimalButton
#:import CardWidget game.widgets.CardWidget

# ============================================================
#  ARENA SCREEN
# ============================================================
<ArenaScreen>:
    FloatLayout:
        id: arena_zone
        canvas.before:
            Color:
                rgba: app.bg_dark
            Rectangle:
                pos: self.pos
                size: self.size

        # --- Top stats bar ---
        BoxLayout:
            pos_hint: {"top": 1, "x": 0}
            size_hint: 1, 0.07
            padding: [15, 5]
            canvas.before:
                Color:
                    rgba: app.nav_bg
                Rectangle:
                    pos: self.pos
                    size: self.size
            # Gold
            Label:
                text: root.gold_text
                font_size: "18sp"
                bold: True
                color: app.accent_gold
                halign: "left"
                text_size: self.size
                valign: "middle"
            # Idle rate
            Label:
                text: root.idle_rate_text
                font_size: "12sp"
                color: app.accent_green
                halign: "center"
                text_size: self.size
                valign: "middle"
            # Wins
            Label:
                text: root.wins_text + " W"
                font_size: "14sp"
                color: app.text_secondary
                halign: "right"
                text_size: self.size
                valign: "middle"

        # --- Central arena area ---
        BoxLayout:
            orientation: "vertical"
            pos_hint: {"top": 0.93, "x": 0}
            size_hint: 1, 0.72
            padding: [20, 10]
            spacing: 5

            # Arena title
            Label:
                text: "A R E N A"
                font_size: "12sp"
                color: app.text_muted
                size_hint_y: 0.04
                letter_spacing: 4

            # --- Player section ---
            BoxLayout:
                size_hint_y: 0.30
                spacing: 10
                # Avatar
                GladiatorAvatar:
                    size_hint_x: 0.35
                    accent_color: app.accent_green
                    tier: app.engine.active_gladiator_idx + 1 if app.engine else 1
                # Info
                BoxLayout:
                    orientation: "vertical"
                    size_hint_x: 0.65
                    spacing: 3
                    Label:
                        text: root.gladiator_name
                        font_size: "17sp"
                        bold: True
                        color: app.accent_green
                        halign: "left"
                        text_size: self.size
                        valign: "bottom"
                        size_hint_y: 0.3
                    Label:
                        text: root.gladiator_level
                        font_size: "11sp"
                        color: app.text_secondary
                        halign: "left"
                        text_size: self.size
                        valign: "top"
                        size_hint_y: 0.15
                    MinimalBar:
                        size_hint_y: 0.15
                        value: root.player_hp_pct
                        bar_color: theme.HP_PLAYER
                        bg_color: theme.HP_PLAYER_BG
                    Label:
                        text: root.gladiator_hp_text
                        font_size: "10sp"
                        color: app.text_muted
                        halign: "left"
                        text_size: self.size
                        valign: "top"
                        size_hint_y: 0.1
                    Widget:
                        size_hint_y: 0.3

            # VS divider
            BoxLayout:
                size_hint_y: 0.06
                padding: [40, 0]
                Widget:
                    canvas:
                        Color:
                            rgba: app.divider
                        Rectangle:
                            pos: self.x, self.center_y
                            size: self.width, 1
                Label:
                    text: "VS"
                    font_size: "14sp"
                    bold: True
                    color: app.accent_red
                    size_hint_x: None
                    width: 40
                Widget:
                    canvas:
                        Color:
                            rgba: app.divider
                        Rectangle:
                            pos: self.x, self.center_y
                            size: self.width, 1

            # --- Enemy section ---
            BoxLayout:
                size_hint_y: 0.30
                spacing: 10
                # Info (left for enemy)
                BoxLayout:
                    orientation: "vertical"
                    size_hint_x: 0.65
                    spacing: 3
                    Label:
                        text: root.enemy_name
                        font_size: "17sp"
                        bold: True
                        color: app.accent_red
                        halign: "right"
                        text_size: self.size
                        valign: "bottom"
                        size_hint_y: 0.3
                    Label:
                        text: root.enemy_tier
                        font_size: "11sp"
                        color: app.text_secondary
                        halign: "right"
                        text_size: self.size
                        valign: "top"
                        size_hint_y: 0.15
                    MinimalBar:
                        size_hint_y: 0.15
                        value: root.enemy_hp_pct
                        bar_color: theme.HP_ENEMY
                        bg_color: theme.HP_ENEMY_BG
                    Label:
                        text: root.enemy_hp_text
                        font_size: "10sp"
                        color: app.text_muted
                        halign: "right"
                        text_size: self.size
                        valign: "top"
                        size_hint_y: 0.1
                    Widget:
                        size_hint_y: 0.3
                # Avatar
                GladiatorAvatar:
                    size_hint_x: 0.35
                    accent_color: app.accent_red
                    tier: app.engine.arena_tier if app.engine else 1

            # Battle log
            Label:
                text: root.battle_log
                font_size: "12sp"
                color: app.text_secondary
                size_hint_y: 0.14
                text_size: self.width, None
                halign: "center"
                valign: "middle"

            # Fight button
            MinimalButton:
                text: "F I G H T"
                btn_color: theme.BTN_FIGHT
                font_size: 20
                size_hint_y: 0.16
                on_press: root.fight()

        # --- Bottom nav ---
        BoxLayout:
            pos_hint: {"y": 0, "x": 0}
            size_hint: 1, 0.08
            padding: [0, 0]
            canvas.before:
                Color:
                    rgba: app.nav_bg
                Rectangle:
                    pos: self.pos
                    size: self.size
                # Top border line
                Color:
                    rgba: app.divider
                Rectangle:
                    pos: self.x, self.top - 1
                    size: self.width, 1

            MinimalButton:
                text: "ARENA"
                btn_color: 0, 0, 0, 0
                text_color: app.accent_gold
                font_size: 13
            MinimalButton:
                text: "ROSTER"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 13
                on_press: app.root.current = "roster"
            MinimalButton:
                text: "SHOP"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 13
                on_press: app.root.current = "shop"


# ============================================================
#  ROSTER SCREEN
# ============================================================
<RosterScreen>:
    BoxLayout:
        orientation: "vertical"
        canvas.before:
            Color:
                rgba: app.bg_dark
            Rectangle:
                pos: self.pos
                size: self.size

        # Top bar
        BoxLayout:
            size_hint_y: 0.07
            padding: [15, 5]
            canvas.before:
                Color:
                    rgba: app.nav_bg
                Rectangle:
                    pos: self.pos
                    size: self.size
            Label:
                text: "R O S T E R"
                font_size: "14sp"
                color: app.accent_green
                halign: "left"
                text_size: self.size
                valign: "middle"
            Label:
                text: root.gold_text
                font_size: "18sp"
                bold: True
                color: app.accent_gold
                halign: "right"
                text_size: self.size
                valign: "middle"

        # Roster list
        ScrollView:
            size_hint_y: 0.77
            bar_width: 2
            bar_color: app.text_muted
            GridLayout:
                id: roster_grid
                cols: 1
                spacing: 8
                padding: [12, 8]
                size_hint_y: None
                height: self.minimum_height

        # Hire button
        BoxLayout:
            size_hint_y: 0.08
            padding: [20, 5]
            MinimalButton:
                text: "+ HIRE GLADIATOR"
                btn_color: theme.BTN_SUCCESS
                font_size: 15
                on_press: root.hire()

        # Bottom nav
        BoxLayout:
            size_hint_y: 0.08
            canvas.before:
                Color:
                    rgba: app.nav_bg
                Rectangle:
                    pos: self.pos
                    size: self.size
                Color:
                    rgba: app.divider
                Rectangle:
                    pos: self.x, self.top - 1
                    size: self.width, 1

            MinimalButton:
                text: "ARENA"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 13
                on_press: app.root.current = "arena"
            MinimalButton:
                text: "ROSTER"
                btn_color: 0, 0, 0, 0
                text_color: app.accent_gold
                font_size: 13
            MinimalButton:
                text: "SHOP"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 13
                on_press: app.root.current = "shop"


# ============================================================
#  SHOP SCREEN
# ============================================================
<ShopScreen>:
    BoxLayout:
        orientation: "vertical"
        canvas.before:
            Color:
                rgba: app.bg_dark
            Rectangle:
                pos: self.pos
                size: self.size

        # Top bar
        BoxLayout:
            size_hint_y: 0.07
            padding: [15, 5]
            canvas.before:
                Color:
                    rgba: app.nav_bg
                Rectangle:
                    pos: self.pos
                    size: self.size
            Label:
                text: "S H O P"
                font_size: "14sp"
                color: app.accent_blue
                halign: "left"
                text_size: self.size
                valign: "middle"
            Label:
                text: root.gold_text
                font_size: "18sp"
                bold: True
                color: app.accent_gold
                halign: "right"
                text_size: self.size
                valign: "middle"

        # Idle rate
        Label:
            text: root.idle_rate_text
            font_size: "13sp"
            color: app.accent_green
            size_hint_y: 0.04

        # Shop items
        ScrollView:
            size_hint_y: 0.73
            bar_width: 2
            bar_color: app.text_muted
            GridLayout:
                id: shop_grid
                cols: 1
                spacing: 8
                padding: [12, 8]
                size_hint_y: None
                height: self.minimum_height

        # Bottom nav
        BoxLayout:
            size_hint_y: 0.08
            canvas.before:
                Color:
                    rgba: app.nav_bg
                Rectangle:
                    pos: self.pos
                    size: self.size
                Color:
                    rgba: app.divider
                Rectangle:
                    pos: self.x, self.top - 1
                    size: self.width, 1

            MinimalButton:
                text: "ARENA"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 13
                on_press: app.root.current = "arena"
            MinimalButton:
                text: "ROSTER"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 13
                on_press: app.root.current = "roster"
            MinimalButton:
                text: "SHOP"
                btn_color: 0, 0, 0, 0
                text_color: app.accent_gold
                font_size: 13
