#:kivy 2.0
#:import theme game.theme
#:import MinimalBar game.widgets.MinimalBar
#:import GladiatorAvatar game.widgets.GladiatorAvatar
#:import MinimalButton game.widgets.MinimalButton
#:import CardWidget game.widgets.CardWidget

# ============================================================
#  SHARED NAV — 6 tabs
# ============================================================
<NavBar@BoxLayout>:
    size_hint_y: 0.06
    canvas.before:
        Color:
            rgba: app.nav_bg
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: app.divider
        Rectangle:
            pos: self.x, self.top - 1
            size: self.width, 1

# ============================================================
#  ARENA (THE PIT) — Battle System
# ============================================================
<ArenaScreen>:
    FloatLayout:
        id: arena_zone
        canvas.before:
            Color:
                rgba: app.bg_dark
            Rectangle:
                pos: self.pos
                size: self.size

        # Top bar
        BoxLayout:
            pos_hint: {"top": 1, "x": 0}
            size_hint: 1, 0.055
            padding: [8, 3]
            canvas.before:
                Color:
                    rgba: app.nav_bg
                Rectangle:
                    pos: self.pos
                    size: self.size
            Label:
                text: root.gold_text
                font_size: "14sp"
                bold: True
                color: app.accent_gold
                halign: "left"
                text_size: self.size
                valign: "middle"
            Label:
                text: root.idle_rate_text
                font_size: "9sp"
                color: app.accent_green
                halign: "center"
                text_size: self.size
                valign: "middle"
            Label:
                text: root.diamond_text + " dia"
                font_size: "10sp"
                color: app.accent_cyan
                halign: "center"
                text_size: self.size
                valign: "middle"
            Label:
                text: root.wins_text
                font_size: "10sp"
                color: app.text_secondary
                halign: "right"
                text_size: self.size
                valign: "middle"

        # Battle arena content
        BoxLayout:
            orientation: "vertical"
            pos_hint: {"top": 0.945, "x": 0}
            size_hint: 1, 0.655
            padding: [12, 4]
            spacing: 2

            # Title + tier
            BoxLayout:
                size_hint_y: 0.06
                Label:
                    text: "T H E   P I T"
                    font_size: "10sp"
                    color: app.text_muted
                    halign: "left"
                    text_size: self.size
                    valign: "middle"
                Label:
                    text: root.tier_text
                    font_size: "10sp"
                    color: app.accent_red
                    halign: "right"
                    text_size: self.size
                    valign: "middle"

            # Player side
            BoxLayout:
                size_hint_y: 0.18
                spacing: 8
                GladiatorAvatar:
                    size_hint_x: 0.22
                    accent_color: app.accent_green
                BoxLayout:
                    orientation: "vertical"
                    size_hint_x: 0.78
                    Label:
                        text: root.player_summary
                        font_size: "13sp"
                        bold: True
                        color: app.accent_green
                        halign: "left"
                        text_size: self.size
                        valign: "middle"
                        size_hint_y: 0.5
                    MinimalBar:
                        size_hint_y: 0.2
                        value: root.player_hp_pct
                        bar_color: theme.HP_PLAYER
                        bg_color: theme.HP_PLAYER_BG

            # VS divider
            BoxLayout:
                size_hint_y: 0.04
                padding: [30, 0]
                Widget:
                    canvas:
                        Color:
                            rgba: app.divider
                        Rectangle:
                            pos: self.x, self.center_y
                            size: self.width, 1
                Label:
                    text: "VS"
                    font_size: "11sp"
                    bold: True
                    color: app.accent_red
                    size_hint_x: None
                    width: 30
                Widget:
                    canvas:
                        Color:
                            rgba: app.divider
                        Rectangle:
                            pos: self.x, self.center_y
                            size: self.width, 1

            # Enemy side
            BoxLayout:
                size_hint_y: 0.18
                spacing: 8
                BoxLayout:
                    orientation: "vertical"
                    size_hint_x: 0.78
                    Label:
                        text: root.enemy_summary
                        font_size: "13sp"
                        bold: True
                        color: app.accent_red
                        halign: "right"
                        text_size: self.size
                        valign: "middle"
                        size_hint_y: 0.5
                    MinimalBar:
                        size_hint_y: 0.2
                        value: root.enemy_hp_pct
                        bar_color: theme.HP_ENEMY
                        bg_color: theme.HP_ENEMY_BG
                GladiatorAvatar:
                    size_hint_x: 0.22
                    accent_color: app.accent_red

            # Battle status
            Label:
                text: root.battle_status
                font_size: "12sp"
                bold: True
                color: app.accent_gold
                size_hint_y: 0.06
                halign: "center"
                text_size: self.width, None

            # Battle log
            Label:
                id: battle_log_label
                text: root.battle_log_text
                font_size: "9sp"
                color: app.text_secondary
                size_hint_y: 0.22
                text_size: self.width - 16, None
                halign: "left"
                valign: "top"

            # Ad bonus
            Label:
                text: root.ad_bonus_text
                font_size: "9sp"
                color: app.accent_cyan
                size_hint_y: 0.03
                halign: "center"

            # Action buttons
            BoxLayout:
                size_hint_y: 0.11
                spacing: 4
                MinimalButton:
                    text: "AUTO"
                    btn_color: theme.BTN_FIGHT
                    font_size: 13
                    on_press: root.start_auto_battle()
                MinimalButton:
                    text: "BOSS"
                    btn_color: theme.ACCENT_PURPLE
                    font_size: 13
                    on_press: root.start_boss_fight()
                MinimalButton:
                    text: "NEXT"
                    btn_color: theme.BTN_PRIMARY
                    font_size: 13
                    on_press: root.next_turn()
                MinimalButton:
                    text: "SKIP"
                    btn_color: theme.BG_ELEVATED
                    text_color: theme.TEXT_SECONDARY
                    font_size: 13
                    on_press: root.skip_battle()

            BoxLayout:
                size_hint_y: 0.08
                spacing: 4
                MinimalButton:
                    text: "2x AD"
                    btn_color: theme.ACCENT_CYAN
                    text_color: theme.BG_DARK
                    font_size: 11
                    on_press: root.watch_ad()

        # Nav
        NavBar:
            pos_hint: {"y": 0, "x": 0}
            MinimalButton:
                text: "PIT"
                btn_color: 0, 0, 0, 0
                text_color: app.accent_gold
                font_size: 10
            MinimalButton:
                text: "SQUAD"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 10
                on_press: app.root.current = "roster"
            MinimalButton:
                text: "ANVIL"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 10
                on_press: app.root.current = "forge"
            MinimalButton:
                text: "HUNTS"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 10
                on_press: app.root.current = "expedition"
            MinimalButton:
                text: "LORE"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 10
                on_press: app.root.current = "lore"
            MinimalButton:
                text: "MORE"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 10
                on_press: app.root.current = "more"


# ============================================================
#  ROSTER (SQUAD)
# ============================================================
<RosterScreen>:
    BoxLayout:
        orientation: "vertical"
        canvas.before:
            Color:
                rgba: app.bg_dark
            Rectangle:
                pos: self.pos
                size: self.size

        BoxLayout:
            size_hint_y: 0.055
            padding: [12, 3]
            canvas.before:
                Color:
                    rgba: app.nav_bg
                Rectangle:
                    pos: self.pos
                    size: self.size
            Label:
                text: "S Q U A D"
                font_size: "12sp"
                color: app.accent_green
                halign: "left"
                text_size: self.size
                valign: "middle"
            Label:
                text: root.graveyard_text
                font_size: "10sp"
                color: app.accent_red
                halign: "center"
                text_size: self.size
                valign: "middle"
            Label:
                text: root.gold_text
                font_size: "16sp"
                bold: True
                color: app.accent_gold
                halign: "right"
                text_size: self.size
                valign: "middle"

        ScrollView:
            size_hint_y: 0.76
            bar_width: 2
            bar_color: app.text_muted
            GridLayout:
                id: roster_grid
                cols: 1
                spacing: 6
                padding: [10, 6]
                size_hint_y: None
                height: self.minimum_height

        BoxLayout:
            size_hint_y: 0.06
            padding: [16, 3]
            MinimalButton:
                text: "+ RECRUIT FIGHTER"
                btn_color: theme.BTN_SUCCESS
                font_size: 13
                on_press: root.hire()

        NavBar:
            MinimalButton:
                text: "PIT"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 10
                on_press: app.root.current = "arena"
            MinimalButton:
                text: "SQUAD"
                btn_color: 0, 0, 0, 0
                text_color: app.accent_gold
                font_size: 10
            MinimalButton:
                text: "ANVIL"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 10
                on_press: app.root.current = "forge"
            MinimalButton:
                text: "HUNTS"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 10
                on_press: app.root.current = "expedition"
            MinimalButton:
                text: "LORE"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 10
                on_press: app.root.current = "lore"
            MinimalButton:
                text: "MORE"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 10
                on_press: app.root.current = "more"


# ============================================================
