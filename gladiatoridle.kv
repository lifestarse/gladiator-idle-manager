                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 10
                on_press: app.root.current = "roster"
            MinimalButton:
                text: "ANVIL"
                btn_color: 0, 0, 0, 0
                text_color: app.accent_gold
                font_size: 10
            MinimalButton:
                text: "HUNTS"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 10
                on_press: app.root.current = "expedition"
            MinimalButton:
                text: "MRKT"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 10
                on_press: app.root.current = "shop"
            MinimalButton:
                text: "GEAR"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 10
                on_press: app.root.current = "settings"


# ============================================================
#  EXPEDITIONS (HUNTS)
