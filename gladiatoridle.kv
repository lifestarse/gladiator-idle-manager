# Build: 5
#:kivy 2.0
#:import dp kivy.metrics.dp
#:import sp kivy.metrics.sp
#:import theme game.theme
#:import MinimalBar game.widgets.MinimalBar
#:import GladiatorAvatar game.widgets.GladiatorAvatar
#:import MinimalButton game.widgets.MinimalButton
#:import NavButton game.widgets.NavButton
#:import CardWidget game.widgets.CardWidget

# ============================================================
#  SHARED NAV — 6 tabs
# ============================================================
<NavBar@BoxLayout>:
    size_hint_y: None
    height: dp(56)
    canvas.before:
        Color:
            rgba: app.nav_bg
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: app.divider
        Rectangle:
            pos: self.x, self.top - 1
            size: self.width, 1

<TopBar@BoxLayout>:
    size_hint_y: None
    height: dp(44)
    padding: [dp(10), dp(4)]
    canvas.before:
        Color:
            rgba: app.nav_bg
        Rectangle:
            pos: self.pos
            size: self.size

# ============================================================
#  ARENA (THE PIT) — Battle System
# ============================================================
<ArenaScreen>:
    FloatLayout:
        id: arena_zone
        canvas.before:
            Color:
                rgba: app.bg_dark
            Rectangle:
                pos: self.pos
                size: self.size
        BoxLayout:
            orientation: "vertical"
            pos: self.parent.pos
            size: self.parent.size

            # Top bar
            TopBar:
                Label:
                    text: app.title_pit
                    font_size: "17sp"
                    color: app.accent_gold
                    halign: "left"
                    text_size: self.size
                    valign: "middle"
                    size_hint_x: None
                    width: dp(80)
                Label:
                    text: root.gold_text
                    font_size: "17sp"
                    bold: True
                    color: app.accent_gold
                    halign: "right"
                    text_size: self.size
                    valign: "middle"
                Image:
                    source: "icons/ic_gold.png"
                    fit_mode: "contain"
                    size_hint: None, 1
                    width: dp(24)
                Label:
                    text: root.diamond_text
                    font_size: "17sp"
                    bold: True
                    color: app.accent_cyan
                    halign: "right"
                    text_size: self.size
                    valign: "middle"
                Image:
                    source: "icons/ic_gem.png"
                    fit_mode: "contain"
                    size_hint: None, 1
                    width: dp(24)
                Label:
                    text: root.wins_text
                    font_size: "17sp"
                    bold: True
                    color: app.text_secondary
                    halign: "right"
                    text_size: self.size
                    valign: "middle"
                Image:
                    source: "icons/ic_trophy.png"
                    fit_mode: "contain"
                    size_hint: None, 1
                    width: dp(24)

            # Battle arena content
            BoxLayout:
                orientation: "vertical"
                padding: [30, 6]
                spacing: 6

                # Record & run info
                BoxLayout:
                    size_hint_y: None
                    height: dp(22)
                    padding: [4, 0]
                    Label:
                        text: root.record_text
                        font_size: "14sp"
                        color: app.accent_gold
                        halign: "left"
                        text_size: self.size
                        valign: "middle"
                    Label:
                        text: root.run_text
                        font_size: "14sp"
                        color: app.accent_cyan
                        halign: "right"
                        text_size: self.size
                        valign: "middle"

                # Tier
                BoxLayout:
                    size_hint_y: None
                    height: dp(26)
                    Label:
                        text: root.tier_text
                        font_size: "19sp"
                        color: app.accent_red
                        halign: "right"
                        text_size: self.size
                        valign: "middle"

                # Player fighters panel
                ScrollView:
                    size_hint_y: 0.42
                    bar_width: 2
                    bar_color: app.text_muted
                    do_scroll_x: False
                    scroll_distance: dp(8)
                    scroll_timeout: 50
                    GridLayout:
                        id: battle_fighters_grid
                        cols: 1
                        spacing: dp(4)
                        padding: [0, 4]
                        size_hint_y: None
                        height: self.minimum_height

                # VS divider
                BoxLayout:
                    size_hint_y: None
                    height: dp(18)
                    padding: [30, 0]
                    Widget:
                        canvas:
                            Color:
                                rgba: app.divider
                            Rectangle:
                                pos: self.x, self.center_y
                                size: self.width, 1
                    Label:
                        text: app.lbl_vs
                        font_size: "21sp"
                        bold: True
                        color: app.accent_red
                        size_hint_x: None
                        width: 30
                    Widget:
                        canvas:
                            Color:
                                rgba: app.divider
                            Rectangle:
                                pos: self.x, self.center_y
                                size: self.width, 1

                # Enemy fighters panel
                ScrollView:
                    size_hint_y: 0.20
                    bar_width: 2
                    bar_color: app.text_muted
                    do_scroll_x: False
                    scroll_distance: dp(8)
                    scroll_timeout: 50
                    GridLayout:
                        id: battle_enemies_grid
                        cols: 1
                        spacing: dp(10)
                        padding: [0, 6]
                        size_hint_y: None
                        height: self.minimum_height

                # Battle status
                Label:
                    text: root.battle_status
                    font_size: "18sp"
                    bold: True
                    color: app.accent_gold
                    size_hint_y: None
                    height: dp(24)
                    halign: "center"
                    text_size: self.width, None

                # Battle log — at bottom, auto-fades
                Label:
                    id: battle_log_label
                    text: root.battle_log_text
                    font_size: "26sp"
                    color: app.text_secondary
                    size_hint_y: 0.18
                    text_size: self.width - 16, None
                    halign: "left"
                    valign: "top"

            # Action buttons — above nav bar
            BoxLayout:
                size_hint_y: None
                height: dp(48)
                padding: [8, 3]
                spacing: 6
                MinimalButton:
                    text: app.lbl_auto
                    btn_color: theme.BTN_FIGHT
                    font_size: "18sp"
                    on_press: root.start_auto_battle()
                MinimalButton:
                    text: app.lbl_boss
                    btn_color: theme.ACCENT_PURPLE
                    font_size: "18sp"
                    on_press: root.start_boss_fight()
                MinimalButton:
                    text: app.lbl_next
                    btn_color: theme.BTN_PRIMARY
                    font_size: "18sp"
                    on_press: root.next_turn()
                MinimalButton:
                    text: app.lbl_skip
                    btn_color: theme.BG_ELEVATED
                    text_color: theme.TEXT_SECONDARY
                    font_size: "18sp"
                    on_press: root.skip_battle()

            # Nav
            NavBar:
                NavButton:
                    text: app.nav_pit
                    icon_source: "icons/ic_four_star.png"
                    is_active: True
                NavButton:
                    text: app.nav_squad
                    icon_source: "icons/ic_squad.png"
                    is_active: False
                    on_press: app.root.current = "roster"
                NavButton:
                    text: app.nav_anvil
                    icon_source: "icons/ic_anvil.png"
                    is_active: False
                    on_press: app.root.current = "forge"
                NavButton:
                    text: app.nav_hunts
                    icon_source: "icons/ic_hunts.png"
                    is_active: False
                    on_press: app.root.current = "expedition"
                NavButton:
                    text: app.nav_lore
                    icon_source: "icons/ic_lore.png"
                    is_active: False
                    on_press: app.root.current = "lore"
                NavButton:
                    text: app.nav_more
                    icon_source: "icons/ic_more.png"
                    is_active: False
                    on_press: app.root.current = "more"
# ============================================================
#  ROSTER (SQUAD)
# ============================================================
<RosterScreen>:
    BoxLayout:
        orientation: "vertical"
        canvas.before:
            Color:
                rgba: app.bg_dark
            Rectangle:
                pos: self.pos
                size: self.size

        TopBar:
            Label:
                text: app.title_squad
                font_size: "17sp"
                color: app.accent_green
                halign: "left"
                text_size: self.size
                valign: "middle"
                size_hint_x: 0.4
            Label:
                text: root.graveyard_text
                font_size: "17sp"
                color: app.accent_red
                halign: "center"
                text_size: self.size
                valign: "middle"
            Label:
                text: root.gold_text
                font_size: "17sp"
                bold: True
                color: app.accent_gold
                halign: "right"
                text_size: self.size
                valign: "middle"
            Image:
                source: "icons/ic_gold.png"
                fit_mode: "contain"
                size_hint: None, 1
                width: dp(24)

        ScrollView:
            bar_width: 2
            bar_color: app.text_muted
            do_scroll_x: False
            scroll_distance: dp(8)
            scroll_timeout: 50
            GridLayout:
                id: roster_grid
                cols: 1
                spacing: 6
                padding: [10, 6]
                size_hint_y: None
                height: self.minimum_height

        BoxLayout:
            size_hint_y: 0.06
            padding: [16, 3]
            spacing: 8
            MinimalButton:
                text: root.hire_cost_text or app.lbl_recruit_fighter
                btn_color: theme.BTN_SUCCESS
                font_size: 18
                on_press: root.hire()
            MinimalButton:
                id: heal_all_btn
                text: root.heal_all_text or app.lbl_heal_all_injuries
                btn_color: theme.ACCENT_GREEN if root.heal_all_enabled == "true" else theme.BTN_DISABLED
                text_color: theme.BG_DARK if root.heal_all_enabled == "true" else theme.TEXT_MUTED
                font_size: 16
                on_press: root.heal_all_injuries()

        NavBar:
            NavButton:
                text: app.nav_pit
                icon_source: "icons/ic_four_star.png"
                is_active: False
                on_press: app.root.current = "arena"
            NavButton:
                text: app.nav_squad
                icon_source: "icons/ic_squad.png"
                is_active: True
            NavButton:
                text: app.nav_anvil
                icon_source: "icons/ic_anvil.png"
                is_active: False
                on_press: app.root.current = "forge"
            NavButton:
                text: app.nav_hunts
                icon_source: "icons/ic_hunts.png"
                is_active: False
                on_press: app.root.current = "expedition"
            NavButton:
                text: app.nav_lore
                icon_source: "icons/ic_lore.png"
                is_active: False
                on_press: app.root.current = "lore"
            NavButton:
                text: app.nav_more
                icon_source: "icons/ic_more.png"
                is_active: False
                on_press: app.root.current = "more"
# ============================================================
#  FORGE (ANVIL)
# ============================================================
<ForgeScreen>:
    BoxLayout:
        orientation: "vertical"
        canvas.before:
            Color:
                rgba: app.bg_dark
            Rectangle:
                pos: self.pos
                size: self.size

        TopBar:
            Label:
                text: app.title_anvil
                font_size: "17sp"
                color: app.accent_red
                halign: "left"
                text_size: self.size
                valign: "middle"
                size_hint_x: 0.4
            Label:
                text: root.gold_text
                font_size: "17sp"
                bold: True
                color: app.accent_gold
                halign: "right"
                text_size: self.size
                valign: "middle"
            Image:
                source: "icons/ic_gold.png"
                fit_mode: "contain"
                size_hint: None, 1
                width: dp(24)


        ScrollView:
            size_hint_y: 0.72
            bar_width: 2
            bar_color: app.text_muted
            do_scroll_x: False
            scroll_distance: dp(8)
            scroll_timeout: 50
            GridLayout:
                id: forge_grid
                cols: 1
                spacing: 6
                padding: [10, 6]
                size_hint_y: None
                height: self.minimum_height

        MinimalButton:
            text: root.inventory_btn_text
            btn_color: theme.ACCENT_CYAN if root.show_inventory else theme.BTN_PRIMARY
            text_color: theme.BG_DARK if root.show_inventory else theme.TEXT_PRIMARY
            font_size: 17
            size_hint_y: None
            height: dp(48)
            on_press: root.toggle_inventory()

        NavBar:
            NavButton:
                text: app.nav_pit
                icon_source: "icons/ic_four_star.png"
                is_active: False
                on_press: app.root.current = "arena"
            NavButton:
                text: app.nav_squad
                icon_source: "icons/ic_squad.png"
                is_active: False
                on_press: app.root.current = "roster"
            NavButton:
                text: app.nav_anvil
                icon_source: "icons/ic_anvil.png"
                is_active: True
            NavButton:
                text: app.nav_hunts
                icon_source: "icons/ic_hunts.png"
                is_active: False
                on_press: app.root.current = "expedition"
            NavButton:
                text: app.nav_lore
                icon_source: "icons/ic_lore.png"
                is_active: False
                on_press: app.root.current = "lore"
            NavButton:
                text: app.nav_more
                icon_source: "icons/ic_more.png"
                is_active: False
                on_press: app.root.current = "more"
# ============================================================
#  EXPEDITIONS (HUNTS)
# ============================================================
<ExpeditionScreen>:
    BoxLayout:
        orientation: "vertical"
        canvas.before:
            Color:
                rgba: app.bg_dark
            Rectangle:
                pos: self.pos
                size: self.size

        TopBar:
            Label:
                text: app.title_hunts
                font_size: "17sp"
                color: app.accent_purple
                halign: "left"
                text_size: self.size
                valign: "middle"
                size_hint_x: 0.4
            Label:
                text: root.gold_text
                font_size: "17sp"
                bold: True
                color: app.accent_gold
                halign: "right"
                text_size: self.size
                valign: "middle"
            Image:
                source: "icons/ic_gold.png"
                fit_mode: "contain"
                size_hint: None, 1
                width: dp(24)

        GridLayout:
            id: expedition_status_grid
            cols: 1
            spacing: 4
            padding: [10, 3]
