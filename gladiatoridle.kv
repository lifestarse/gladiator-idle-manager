#:kivy 2.0
#:import theme game.theme
#:import MinimalBar game.widgets.MinimalBar
#:import GladiatorAvatar game.widgets.GladiatorAvatar
#:import MinimalButton game.widgets.MinimalButton
#:import CardWidget game.widgets.CardWidget

# ============================================================
#  SHARED NAV BAR TEMPLATE
# ============================================================

<NavBar@BoxLayout>:
    size_hint_y: 0.065
    canvas.before:
        Color:
            rgba: app.nav_bg
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: app.divider
        Rectangle:
            pos: self.x, self.top - 1
            size: self.width, 1

# ============================================================
#  ARENA
# ============================================================
<ArenaScreen>:
    FloatLayout:
        id: arena_zone
        canvas.before:
            Color:
                rgba: app.bg_dark
            Rectangle:
                pos: self.pos
                size: self.size

        # Top bar
        BoxLayout:
            pos_hint: {"top": 1, "x": 0}
            size_hint: 1, 0.06
            padding: [15, 4]
            canvas.before:
                Color:
                    rgba: app.nav_bg
                Rectangle:
                    pos: self.pos
                    size: self.size
            Label:
                text: root.gold_text
                font_size: "17sp"
                bold: True
                color: app.accent_gold
                halign: "left"
                text_size: self.size
                valign: "middle"
            Label:
                text: root.idle_rate_text
                font_size: "11sp"
                color: app.accent_green
                halign: "center"
                text_size: self.size
                valign: "middle"
            Label:
                text: root.wins_text + " W"
                font_size: "13sp"
                color: app.text_secondary
                halign: "right"
                text_size: self.size
                valign: "middle"

        # Arena content
        BoxLayout:
            orientation: "vertical"
            pos_hint: {"top": 0.94, "x": 0}
            size_hint: 1, 0.685
            padding: [20, 8]
            spacing: 4

            Label:
                text: "T H E   P I T"
                font_size: "11sp"
                color: app.text_muted
                size_hint_y: 0.04

            # Player
            BoxLayout:
                size_hint_y: 0.28
                spacing: 10
                GladiatorAvatar:
                    size_hint_x: 0.3
                    accent_color: app.accent_green
                BoxLayout:
                    orientation: "vertical"
                    size_hint_x: 0.7
                    spacing: 2
                    Label:
                        text: root.gladiator_name
                        font_size: "16sp"
                        bold: True
                        color: app.accent_green
                        halign: "left"
                        text_size: self.size
                        valign: "bottom"
                        size_hint_y: 0.25
                    Label:
                        text: root.gladiator_level
                        font_size: "10sp"
                        color: app.text_secondary
                        halign: "left"
                        text_size: self.size
                        valign: "top"
                        size_hint_y: 0.12
                    MinimalBar:
                        size_hint_y: 0.12
                        value: root.player_hp_pct
                        bar_color: theme.HP_PLAYER
                        bg_color: theme.HP_PLAYER_BG
                    Label:
                        text: root.gladiator_hp_text
                        font_size: "9sp"
                        color: app.text_muted
                        halign: "left"
                        text_size: self.size
                        size_hint_y: 0.1
                    Label:
                        text: root.injuries_text + "  " + root.death_risk_text
                        font_size: "9sp"
                        color: app.accent_red
                        halign: "left"
                        text_size: self.size
                        size_hint_y: 0.1
                    Widget:
                        size_hint_y: 0.31

            # VS
            BoxLayout:
                size_hint_y: 0.05
                padding: [40, 0]
                Widget:
                    canvas:
                        Color:
                            rgba: app.divider
                        Rectangle:
                            pos: self.x, self.center_y
                            size: self.width, 1
                Label:
                    text: "VS"
                    font_size: "13sp"
                    bold: True
                    color: app.accent_red
                    size_hint_x: None
                    width: 36
                Widget:
                    canvas:
                        Color:
                            rgba: app.divider
                        Rectangle:
                            pos: self.x, self.center_y
                            size: self.width, 1

            # Enemy
            BoxLayout:
                size_hint_y: 0.28
                spacing: 10
                BoxLayout:
                    orientation: "vertical"
                    size_hint_x: 0.7
                    spacing: 2
                    Label:
                        text: root.enemy_name
                        font_size: "16sp"
                        bold: True
                        color: app.accent_red
                        halign: "right"
                        text_size: self.size
                        valign: "bottom"
                        size_hint_y: 0.3
                    Label:
                        text: root.enemy_tier
                        font_size: "10sp"
                        color: app.text_secondary
                        halign: "right"
                        text_size: self.size
                        valign: "top"
                        size_hint_y: 0.15
                    MinimalBar:
                        size_hint_y: 0.12
                        value: root.enemy_hp_pct
                        bar_color: theme.HP_ENEMY
                        bg_color: theme.HP_ENEMY_BG
                    Label:
                        text: root.enemy_hp_text
                        font_size: "9sp"
                        color: app.text_muted
                        halign: "right"
                        text_size: self.size
                        size_hint_y: 0.1
                    Widget:
                        size_hint_y: 0.33
                GladiatorAvatar:
                    size_hint_x: 0.3
                    accent_color: app.accent_red

            # Log
            Label:
                text: root.battle_log
                font_size: "11sp"
                color: app.text_secondary
                size_hint_y: 0.13
                text_size: self.width, None
                halign: "center"
                valign: "middle"

            # Fight
            MinimalButton:
                text: "F I G H T"
                btn_color: theme.BTN_FIGHT
                font_size: 19
                size_hint_y: 0.14
                on_press: root.fight()

        # Nav
        NavBar:
            pos_hint: {"y": 0, "x": 0}
            MinimalButton:
                text: "PIT"
                btn_color: 0, 0, 0, 0
                text_color: app.accent_gold
                font_size: 11
            MinimalButton:
                text: "SQUAD"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 11
                on_press: app.root.current = "roster"
            MinimalButton:
                text: "ANVIL"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 11
                on_press: app.root.current = "forge"
            MinimalButton:
                text: "HUNTS"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 11
                on_press: app.root.current = "expedition"
            MinimalButton:
                text: "MARKET"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 11
                on_press: app.root.current = "shop"


# ============================================================
#  ROSTER (SQUAD)
# ============================================================
<RosterScreen>:
    BoxLayout:
        orientation: "vertical"
        canvas.before:
            Color:
                rgba: app.bg_dark
            Rectangle:
                pos: self.pos
                size: self.size

        # Top bar
        BoxLayout:
            size_hint_y: 0.06
            padding: [15, 4]
            canvas.before:
                Color:
                    rgba: app.nav_bg
                Rectangle:
                    pos: self.pos
                    size: self.size
            Label:
                text: "S Q U A D"
                font_size: "13sp"
                color: app.accent_green
                halign: "left"
                text_size: self.size
                valign: "middle"
            Label:
                text: root.graveyard_text
                font_size: "11sp"
                color: app.accent_red
                halign: "center"
                text_size: self.size
                valign: "middle"
            Label:
                text: root.gold_text
                font_size: "17sp"
                bold: True
                color: app.accent_gold
                halign: "right"
                text_size: self.size
                valign: "middle"

        ScrollView:
            size_hint_y: 0.745
            bar_width: 2
            bar_color: app.text_muted
            GridLayout:
                id: roster_grid
                cols: 1
                spacing: 8
                padding: [12, 8]
                size_hint_y: None
                height: self.minimum_height

        BoxLayout:
            size_hint_y: 0.065
            padding: [20, 4]
            MinimalButton:
                text: "+ RECRUIT FIGHTER"
                btn_color: theme.BTN_SUCCESS
                font_size: 14
                on_press: root.hire()

        NavBar:
            MinimalButton:
                text: "PIT"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 11
                on_press: app.root.current = "arena"
            MinimalButton:
                text: "SQUAD"
                btn_color: 0, 0, 0, 0
                text_color: app.accent_gold
                font_size: 11
            MinimalButton:
                text: "ANVIL"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 11
                on_press: app.root.current = "forge"
            MinimalButton:
                text: "HUNTS"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 11
                on_press: app.root.current = "expedition"
            MinimalButton:
                text: "MARKET"
                btn_color: 0, 0, 0, 0
                text_color: app.text_secondary
                font_size: 11
                on_press: app.root.current = "shop"


# ============================================================
#  FORGE (ANVIL)
# ============================================================
<ForgeScreen>:
    BoxLayout:
        orientation: "vertical"
        canvas.before:
            Color:
                rgba: app.bg_dark
            Rectangle:
                pos: self.pos
                size: self.size

        # Top bar
        BoxLayout:
            size_hint_y: 0.06
            padding: [15, 4]
            canvas.before:
