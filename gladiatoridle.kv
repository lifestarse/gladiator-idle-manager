# Build: 44
#:kivy 2.0
#:import dp kivy.metrics.dp
#:import sp kivy.metrics.sp
#:import theme game.theme
#:import MinimalBar game.widgets.MinimalBar
#:import GladiatorAvatar game.widgets.GladiatorAvatar
#:import MinimalButton game.widgets.MinimalButton
#:import NavButton game.widgets.NavButton
#:import NavBar game.widgets.NavBar
#:import CardWidget game.widgets.CardWidget
#:import ScrollEffect kivy.effects.scroll.ScrollEffect
#:import TouchPanel game.widgets.TouchPanel
#:import TouchScrollView game.widgets.TouchScrollView
#:import TouchRecycleView game.widgets.TouchRecycleView
#:import AutoShrinkLabel game.widgets.AutoShrinkLabel
#:import RosterCardView game.ui_helpers.RosterCardView
#:import ForgeCardView game.ui_helpers.ForgeCardView
#:import InventoryCardView game.ui_helpers.InventoryCardView

# ============================================================
#  SHARED NAV — 6 tabs (set active_screen per screen)
# ============================================================
<NavBar>:
    active_screen: app.sm.current if app.sm else ""
    size_hint_y: None
    height: dp(70)
    canvas.before:
        Color:
            rgba: app.nav_bg
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: app.divider
        Rectangle:
            pos: self.x, self.top - 1
            size: self.width, dp(1)
    NavButton:
        text: app.nav_pit
        icon_source: "sprites/nav/nav_arena.png"
        is_active: root.active_screen == "arena"
        on_press: app.sm.current = "arena"
    NavButton:
        text: app.nav_squad
        icon_source: "sprites/nav/nav_roster.png"
        is_active: root.active_screen == "roster"
        on_press: app.sm.current = "roster"
    NavButton:
        text: app.nav_anvil
        icon_source: "sprites/nav/nav_forge.png"
        is_active: root.active_screen == "forge"
        on_press: app.sm.current = "forge"
    NavButton:
        text: app.nav_hunts
        icon_source: "sprites/nav/nav_expedition.png"
        is_active: root.active_screen == "expedition"
        on_press: app.sm.current = "expedition"
    NavButton:
        text: app.nav_lore
        icon_source: "sprites/nav/nav_lore.png"
        is_active: root.active_screen == "lore"
        on_press: app.sm.current = "lore"
    NavButton:
        text: app.nav_more
        icon_source: "sprites/nav/nav_more.png"
        is_active: root.active_screen == "more"
        on_press: app.sm.current = "more"

<TopBar@BoxLayout>:
    title_text: ""
    title_color: app.accent_gold
    size_hint_y: None
    height: dp(56)
    padding: [dp(8), dp(4)]
    spacing: dp(4)
    canvas.before:
        Color:
            rgba: app.nav_bg
        Rectangle:
            pos: self.pos
            size: self.size
    AutoShrinkLabel:
        text: self.parent.title_text if self.parent else ""
        font_size: "14sp"
        bold: True
        color: self.parent.title_color if self.parent else [1,1,1,1]
        halign: "left"
        text_size: self.size
        valign: "middle"
        size_hint_x: 0.40
    BoxLayout:
        spacing: 0
        size_hint_x: 0.30
        AutoShrinkLabel:
            text: app.top_gold
            font_size: "12sp"
            bold: True
            color: app.accent_gold
            halign: "right"
            text_size: self.size
            valign: "middle"
        Image:
            source: "sprites/icons/ic_gold.png"
            fit_mode: "contain"
            size_hint: None, 1
            width: dp(20)
    BoxLayout:
        spacing: 0
        size_hint_x: 0.30
        AutoShrinkLabel:
            text: app.top_diamonds
            font_size: "12sp"
            bold: True
            color: app.accent_cyan
            halign: "right"
            text_size: self.size
            valign: "middle"
        Image:
            source: "sprites/icons/ic_gem.png"
            fit_mode: "contain"
            size_hint: None, 1
            width: dp(20)

# ============================================================
#  ARENA (THE PIT) — Battle System
# ============================================================
<ArenaScreen>:
    FloatLayout:
        id: arena_zone
        canvas.before:
            Color:
                rgba: app.bg_dark
            Rectangle:
                pos: self.pos
                size: self.size
            Color:
                rgba: 1, 1, 1, 0.25
            BorderImage:
                source: "sprites/bg/bg_arena.png"
                pos: self.pos
                size: self.size
        BoxLayout:
            orientation: "vertical"
            pos: self.parent.pos
            size: self.parent.size

            # Top bar
            TopBar:
                title_text: app.title_pit
                title_color: app.accent_gold

            # Detail/tutorial view (hidden during battle)
            TouchScrollView:
                bar_width: 2
                bar_color: app.text_muted
                do_scroll_x: False
                effect_cls: ScrollEffect
                opacity: 0 if root.arena_view == "battle" else 1
                size_hint_y: 0.001 if root.arena_view == "battle" else 1
                disabled: root.arena_view == "battle"
                GridLayout:
                    id: enemy_detail_grid
                    cols: 1
                    spacing: dp(8)
                    padding: [dp(16), dp(12)]
                    size_hint_y: None
                    height: self.minimum_height

            MinimalButton:
                id: enemy_back_btn
                text: app.lbl_back_btn
                btn_color: theme.BTN_PRIMARY
                font_size: 11
                size_hint_y: None
                height: dp(48) if root.arena_view != "battle" else 0
                opacity: 1 if root.arena_view != "battle" else 0
                disabled: root.arena_view == "battle"
                on_press: app.go_back()

            # Battle arena content
            TouchPanel:
                orientation: "vertical"
                spacing: dp(4)
                opacity: 1 if root.arena_view == "battle" else 0
                size_hint_y: 1 if root.arena_view == "battle" else 0.001
                disabled: root.arena_view != "battle"

                # Stats bar: Run · Tier — compact single row
                BoxLayout:
                    size_hint_y: None
                    height: dp(40)
                    padding: [dp(8), 0]
                    spacing: dp(4)
                    canvas.before:
                        Color:
                            rgba: app.nav_bg
                        Rectangle:
                            pos: self.pos
                            size: self.size
                    AutoShrinkLabel:
                        text: root.run_text
                        font_size: "11sp"
                        bold: True
                        color: app.accent_cyan
                        halign: "left"
                        text_size: self.size
                        valign: "middle"
                        size_hint_x: 0.6
                    AutoShrinkLabel:
                        text: root.tier_text
                        font_size: "12sp"
                        bold: True
                        color: app.accent_red
                        halign: "right"
                        text_size: self.size
                        valign: "middle"
                        size_hint_x: 0.4

                # Heal button (filled from Python)
                BoxLayout:
                    id: heal_btn_box
                    size_hint_y: None
                    height: dp(48)
                    padding: [dp(14), 0]

                # Player fighters panel (padded)
                ScrollView:
                    size_hint_y: 0.42
                    bar_width: 2
                    bar_color: app.text_muted
                    do_scroll_x: False
                    effect_cls: ScrollEffect
                    scroll_distance: dp(8)
                    scroll_timeout: 50
                    GridLayout:
                        id: battle_fighters_grid
                        cols: 1
                        spacing: dp(6)
                        padding: [dp(14), dp(6)]
                        size_hint_y: None
                        height: self.minimum_height

                # Swords divider
                BoxLayout:
                    size_hint_y: None
                    height: dp(24)
                    padding: [dp(14), 0]
                    Widget:
                        canvas:
                            Color:
                                rgba: app.divider
                            Rectangle:
                                pos: self.x, self.center_y
                                size: self.width, dp(1)
                    Image:
                        source: "sprites/icons/ic_swords.png"
                        fit_mode: "contain"
                        size_hint: None, 1
                        width: dp(24)
                        color: app.accent_red
                    Widget:
                        canvas:
                            Color:
                                rgba: app.divider
                            Rectangle:
                                pos: self.x, self.center_y
                                size: self.width, dp(1)

                # Enemy fighters panel
                ScrollView:
                    size_hint_y: 0.35
                    bar_width: 2
                    bar_color: app.text_muted
                    do_scroll_x: False
                    effect_cls: ScrollEffect
                    scroll_distance: dp(8)
                    scroll_timeout: 50
                    GridLayout:
                        id: battle_enemies_grid
                        cols: 1
                        spacing: dp(6)
                        padding: [dp(14), dp(6)]
                        size_hint_y: None
                        height: self.minimum_height

            # Action buttons — above nav bar
            BoxLayout:
                size_hint_y: None
                height: dp(56)
                padding: [dp(8), dp(2)]
                spacing: dp(6)
                MinimalButton:
                    text: app.lbl_auto
                    btn_color: theme.BTN_DISABLED if root.is_fighting else theme.BTN_FIGHT
                    text_color: theme.TEXT_MUTED if root.is_fighting else theme.TEXT_PRIMARY
                    font_size: "11sp"
                    on_press: root.start_auto_battle()
                MinimalButton:
                    text: app.lbl_common if root.arena_mode == "boss" else app.lbl_boss
                    btn_color: theme.BTN_DISABLED if root.is_fighting else (theme.BTN_PRIMARY if root.arena_mode == "boss" else theme.ACCENT_PURPLE)
                    text_color: theme.TEXT_MUTED if root.is_fighting else theme.TEXT_PRIMARY
                    font_size: "11sp"
                    on_press: root.toggle_arena_mode()
                MinimalButton:
                    text: app.lbl_skip
                    btn_color: theme.ACCENT_GOLD if root.is_fighting else theme.BG_ELEVATED
                    text_color: theme.BG_DARK if root.is_fighting else theme.TEXT_SECONDARY
                    font_size: "11sp"
                    on_press: root.skip_battle()
# ============================================================
#  ROSTER (SQUAD)
# ============================================================
<RosterScreen>:
    BoxLayout:
        orientation: "vertical"
        canvas.before:
            Color:
                rgba: app.bg_dark
            Rectangle:
                pos: self.pos
                size: self.size
            Color:
                rgba: 1, 1, 1, 0.25
            BorderImage:
                source: "sprites/bg/bg_default.png"
                pos: self.pos
                size: self.size

        TopBar:
            title_text: app.title_squad
            title_color: app.accent_green

        TouchRecycleView:
            id: roster_rv
            viewclass: 'RosterCardView'
            bar_width: 2
            bar_color: app.text_muted
            do_scroll_x: False
            scroll_type: ['bars', 'content']
            effect_cls: ScrollEffect
            scroll_distance: dp(8)
            scroll_timeout: 50
            opacity: 1 if root.roster_view == "list" else 0
            size_hint_y: 1 if root.roster_view == "list" else 0.001
            disabled: root.roster_view != "list"
            RecycleBoxLayout:
                default_size: None, dp(84)
                default_size_hint: 1, None
                size_hint_y: None
                height: self.minimum_height
                orientation: 'vertical'
                spacing: dp(6)
                padding: [dp(14), dp(8)]

        TouchScrollView:
            id: detail_scroll
            bar_width: 2
            bar_color: app.text_muted
            do_scroll_x: False
            effect_cls: ScrollEffect
            opacity: 0 if root.roster_view == "list" else 1
            size_hint_y: 0.001 if root.roster_view == "list" else 1
            disabled: root.roster_view == "list"
            GridLayout:
                id: detail_grid
                cols: 1
                spacing: dp(6)
                padding: [dp(14), dp(8)]
                size_hint_y: None
                height: self.minimum_height

        MinimalButton:
            id: detail_back_btn
            text: app.lbl_back_btn
            btn_color: theme.BTN_PRIMARY
            font_size: 11
            size_hint_y: None
            height: dp(48) if root.roster_view != "list" else 0
            opacity: 1 if root.roster_view != "list" else 0
            disabled: root.roster_view == "list"
            on_press: app.go_back()

        TouchPanel:
            orientation: "vertical"
            size_hint_y: None
            height: (dp(48) + (dp(48) if root.has_injuries == "true" else 0)) if root.roster_view == "list" else (dp(48) if root.roster_view == "class_detail" else 0)
            opacity: 1 if root.roster_view in ("list", "class_detail") else 0
            disabled: root.roster_view not in ("list", "class_detail")
            padding: [dp(8), dp(2)]
            spacing: dp(4)
            MinimalButton:
                text: root.hire_cost_text or app.lbl_recruit_fighter
                btn_color: theme.BTN_SUCCESS if root.hire_enabled == "true" else theme.BTN_DISABLED
                text_color: theme.BG_DARK if root.hire_enabled == "true" else theme.TEXT_MUTED
                font_size: 11
                size_hint_y: None
                height: dp(48) if root.roster_view in ("list", "class_detail") else 0
                opacity: 1 if root.roster_view in ("list", "class_detail") else 0
                icon_source: "sprites/icons/ic_gold.png"
                disabled: root.roster_view not in ("list", "class_detail")
                on_press: root.hire()
            MinimalButton:
                id: heal_all_btn
                text: root.heal_all_text or app.lbl_heal_all_injuries
                btn_color: theme.ACCENT_GREEN if root.heal_all_enabled == "true" else theme.BTN_DISABLED
                text_color: theme.BG_DARK if root.heal_all_enabled == "true" else theme.TEXT_MUTED
                font_size: 11
                size_hint_y: None
                height: dp(48) if root.has_injuries == "true" and root.roster_view == "list" else 0
                opacity: 1 if root.has_injuries == "true" and root.roster_view == "list" else 0
                disabled: root.roster_view != "list" or root.has_injuries != "true"
                icon_source: "sprites/icons/ic_gold.png"
                on_press: root.heal_all_injuries()
# ============================================================
#  FORGE (ANVIL)
# ============================================================
<ForgeScreen>:
    BoxLayout:
        orientation: "vertical"
        canvas.before:
            Color:
                rgba: app.bg_dark
            Rectangle:
                pos: self.pos
                size: self.size
            Color:
                rgba: 1, 1, 1, 0.25
            BorderImage:
                source: "sprites/bg/bg_forge.png"
                pos: self.pos
                size: self.size

        TopBar:
            title_text: root.lbl_top_title
            title_color: app.accent_red if not root.show_inventory else app.accent_cyan

        TouchPanel:
            id: shop_tabs_box
            size_hint_y: None
            height: dp(48) if not root.show_inventory else 0
            opacity: 0 if root.show_inventory else 1
            disabled: root.show_inventory
            spacing: dp(4)
            padding: [dp(8), dp(2)]
            MinimalButton:
                text: app.lbl_tab_weapon
                btn_color: theme.ACCENT_RED if root.forge_tab == "weapon" else theme.BTN_DISABLED
                text_color: theme.TEXT_PRIMARY if root.forge_tab == "weapon" else theme.TEXT_MUTED
                font_size: 11
                on_press: root.set_forge_tab("weapon")
            MinimalButton:
                text: app.lbl_tab_armor
                btn_color: theme.ACCENT_BLUE if root.forge_tab == "armor" else theme.BTN_DISABLED
                text_color: theme.TEXT_PRIMARY if root.forge_tab == "armor" else theme.TEXT_MUTED
                font_size: 11
                on_press: root.set_forge_tab("armor")
            MinimalButton:
                text: app.lbl_tab_accessory
                btn_color: theme.ACCENT_PURPLE if root.forge_tab == "accessory" else theme.BTN_DISABLED
                text_color: theme.TEXT_PRIMARY if root.forge_tab == "accessory" else theme.TEXT_MUTED
                font_size: 11
                on_press: root.set_forge_tab("accessory")

        TouchPanel:
            id: inv_tabs_box
            orientation: "vertical"
            size_hint_y: None
            height: self.minimum_height if root._show_inv_tabs else 0
            opacity: 1 if root._show_inv_tabs else 0
            disabled: not root._show_inv_tabs

        # Shop-list mode: RecycleView virtualizes 130-item shop grid
        TouchRecycleView:
            id: forge_rv
            viewclass: 'ForgeCardView'
            bar_width: 2
            bar_color: app.text_muted
            do_scroll_x: False
            scroll_type: ['bars', 'content']
            effect_cls: ScrollEffect
            scroll_distance: dp(8)
            scroll_timeout: 50
            size_hint_y: 1 if root._forge_rv_active else 0.001
            opacity: 1 if root._forge_rv_active else 0
            disabled: not root._forge_rv_active
            RecycleBoxLayout:
                default_size: None, dp(114)
                default_size_hint: 1, None
                size_hint_y: None
                height: self.minimum_height
                orientation: 'vertical'
                spacing: dp(6)
                padding: [dp(14), dp(8)]

        # Inventory-list mode: RecycleView for player's items (inv + equipped)
        TouchRecycleView:
            id: inventory_rv
            viewclass: 'InventoryCardView'
            bar_width: 2
            bar_color: app.text_muted
            do_scroll_x: False
            scroll_type: ['bars', 'content']
            effect_cls: ScrollEffect
            scroll_distance: dp(8)
            scroll_timeout: 50
            size_hint_y: 1 if root._inventory_rv_active else 0.001
            opacity: 1 if root._inventory_rv_active else 0
            disabled: not root._inventory_rv_active
            RecycleBoxLayout:
                default_size: None, dp(75)
                default_size_hint: 1, None
                size_hint_y: None
                height: self.minimum_height
                orientation: 'vertical'
                spacing: dp(6)
                padding: [dp(14), dp(8)]

        # Detail/upgrade/enchant/shard modes: legacy GridLayout in ScrollView
        ScrollView:
            id: forge_scroll
            bar_width: 2
            bar_color: app.text_muted
            do_scroll_x: False
            effect_cls: ScrollEffect
            scroll_distance: dp(8)
            scroll_timeout: 50
            size_hint_y: 0.001 if (root._forge_rv_active or root._inventory_rv_active) else 1
            opacity: 0 if (root._forge_rv_active or root._inventory_rv_active) else 1
            disabled: root._forge_rv_active or root._inventory_rv_active
            GridLayout:
                id: forge_grid
                cols: 1
                spacing: dp(6)
                padding: [dp(14), dp(8)]
                size_hint_y: None
                height: self.minimum_height

        MinimalButton:
            id: forge_back_btn
            text: app.lbl_back_btn
            btn_color: theme.BTN_PRIMARY
            font_size: 11
            size_hint_y: None
            height: dp(48) if (root.inv_detail_idx != -1 or root.eq_detail_fighter != -1 or not root._show_inv_tabs) else 0
            opacity: 1 if (root.inv_detail_idx != -1 or root.eq_detail_fighter != -1 or not root._show_inv_tabs) else 0
            disabled: root._show_inv_tabs and root.inv_detail_idx == -1 and root.eq_detail_fighter == -1
            on_press: app.go_back()

        MinimalButton:
            text: root.inventory_btn_text
            btn_color: theme.ACCENT_CYAN if root.show_inventory else theme.BTN_PRIMARY
            text_color: theme.BG_DARK if root.show_inventory else theme.TEXT_PRIMARY
            font_size: 11
            size_hint_y: None
            height: dp(48)
            on_press: root.toggle_inventory()
# ============================================================
#  EXPEDITIONS (HUNTS)
# ============================================================
<ExpeditionScreen>:
    BoxLayout:
        orientation: "vertical"
        canvas.before:
            Color:
                rgba: app.bg_dark
            Rectangle:
                pos: self.pos
                size: self.size
            Color:
                rgba: 1, 1, 1, 0.25
            BorderImage:
                source: "sprites/bg/bg_expedition.png"
                pos: self.pos
                size: self.size

        TopBar:
            title_text: app.title_hunts
            title_color: app.accent_purple

        TouchPanel:
            size_hint_y: None
            height: dp(48) if root.has_active_missions else 0
            opacity: 1 if root.has_active_missions else 0
            disabled: not root.has_active_missions
            padding: [dp(8), dp(4)]
            spacing: dp(6)
            MinimalButton:
                text: app.lbl_tab_missions
                btn_color: theme.ACCENT_CYAN if root.expedition_tab == "missions" else theme.BTN_DISABLED
                text_color: theme.TEXT_PRIMARY if root.expedition_tab == "missions" else theme.TEXT_MUTED
                font_size: 11
                on_press: root.set_expedition_tab("missions")
            MinimalButton:
                text: app.lbl_tab_hunts
                btn_color: theme.ACCENT_GOLD if root.expedition_tab == "hunts" else theme.BTN_DISABLED
                text_color: theme.TEXT_PRIMARY if root.expedition_tab == "hunts" else theme.TEXT_MUTED
                font_size: 11
                on_press: root.set_expedition_tab("hunts")

        ScrollView:
            bar_width: 2
            bar_color: app.text_muted
            do_scroll_x: False
            effect_cls: ScrollEffect
            scroll_distance: dp(8)
            scroll_timeout: 50
            GridLayout:
                id: expedition_grid
                cols: 1
                spacing: dp(6)
                padding: [dp(14), dp(8)]
                size_hint_y: None
                height: self.minimum_height
# ============================================================
#  LORE (Story + Achievements + Diamond Shop)
# ============================================================
<LoreScreen>:
    BoxLayout:
        orientation: "vertical"
        canvas.before:
            Color:
                rgba: app.bg_dark
            Rectangle:
                pos: self.pos
                size: self.size

        # Top bar
        TopBar:
            title_text: app.title_lore
            title_color: app.accent_purple

        TouchPanel:
            size_hint_y: None
            height: dp(48)
            spacing: dp(4)
            padding: [dp(8), dp(2)]
            MinimalButton:
                text: app.lbl_achievements
                btn_color: theme.ACCENT_GOLD if root.lore_tab == "achievements" else theme.BTN_DISABLED
                text_color: theme.TEXT_PRIMARY if root.lore_tab == "achievements" else theme.TEXT_MUTED
                font_size: 11
                on_press: root.set_lore_tab("achievements")
            MinimalButton:
                text: app.lbl_diamond_shop
                btn_color: theme.ACCENT_CYAN if root.lore_tab == "shop" else theme.BTN_DISABLED
                text_color: theme.TEXT_PRIMARY if root.lore_tab == "shop" else theme.TEXT_MUTED
                font_size: 11
                on_press: root.set_lore_tab("shop")
            MinimalButton:
                text: app.lbl_quests
                btn_color: theme.ACCENT_GOLD if root.lore_tab == "quests" else theme.BTN_DISABLED
                text_color: theme.TEXT_PRIMARY if root.lore_tab == "quests" else theme.TEXT_MUTED
                font_size: 11
                on_press: root.set_lore_tab("quests")
            MinimalButton:
                text: app.lbl_stats
                btn_color: theme.ACCENT_GREEN if root.lore_tab == "stats" else theme.BTN_DISABLED
                text_color: theme.TEXT_PRIMARY if root.lore_tab == "stats" else theme.TEXT_MUTED
                font_size: 11
                on_press: root.set_lore_tab("stats")

        ScrollView:
            bar_width: 2
            bar_color: app.text_muted
            do_scroll_x: False
            effect_cls: ScrollEffect
            scroll_distance: dp(8)
            scroll_timeout: 50
            GridLayout:
                id: lore_grid
                cols: 1
                spacing: dp(4)
                padding: [dp(14), dp(8)]
                size_hint_y: None
                height: self.minimum_height

        MinimalButton:
            id: lore_back_btn
            text: app.lbl_back_btn
            btn_color: theme.BTN_PRIMARY
            font_size: 11
            size_hint_y: None
            height: dp(48) if root.lore_subview else 0
            opacity: 1 if root.lore_subview else 0
            disabled: not root.lore_subview
            on_press: app.go_back()

        # Bottom buttons — fixed at bottom, only on stats tab
        BoxLayout:
            size_hint_y: None
            height: dp(52) if root.lore_tab == "stats" and not root.lore_subview else 0
            opacity: 1 if root.lore_tab == "stats" and not root.lore_subview else 0
            padding: [dp(8), dp(2)]
            spacing: dp(4)
            MinimalButton:
                text: root.battle_log_count or ""
                btn_color: theme.ACCENT_CYAN
                text_color: theme.BG_DARK
                font_size: 11
                on_press: root._show_battle_log()
            MinimalButton:
                text: root.event_log_count or ""
                btn_color: theme.ACCENT_GOLD
                text_color: theme.BG_DARK
                font_size: 11
                on_press: root._show_event_log()
# ============================================================
#  MORE (Settings)
# ============================================================
<MoreScreen>:
    BoxLayout:
        orientation: "vertical"
        canvas.before:
            Color:
                rgba: app.bg_dark
            Rectangle:
                pos: self.pos
                size: self.size
            Color:
                rgba: 1, 1, 1, 0.25
            BorderImage:
                source: "sprites/bg/bg_default.png"
                pos: self.pos
                size: self.size

        TopBar:
            title_text: app.title_more
            title_color: app.accent_blue

        ScrollView:
            bar_width: 2
            bar_color: app.text_muted
            do_scroll_x: False
            effect_cls: ScrollEffect
            scroll_distance: dp(8)
            scroll_timeout: 50
            GridLayout:
                cols: 1
                spacing: dp(8)
                padding: [dp(14), dp(10)]
                size_hint_y: None
                height: self.minimum_height

                # --- Remove Ads (hidden when already removed) ---
                AutoShrinkLabel:
                    text: app.lbl_remove_ads
                    font_size: "12sp"
                    bold: True
                    color: app.text_primary
                    halign: "center"
                    text_size: self.width, None
                    size_hint_y: None
                    height: 0 if root.ads_hidden else dp(34)
                    opacity: 0 if root.ads_hidden else 1

                AutoShrinkLabel:
                    text: root.ads_status
                    font_size: "11sp"
                    color: app.text_muted
                    halign: "center"
                    text_size: self.width, None
                    size_hint_y: None
                    height: 0 if root.ads_hidden else dp(26)
                    opacity: 0 if root.ads_hidden else 1

                MinimalButton:
                    id: ads_buy_btn
                    text: app.lbl_remove_ads_buy
                    btn_color: app.accent_gold
                    text_color: app.bg_dark
                    font_size: "12sp"
                    size_hint_y: None
                    height: 0 if root.ads_hidden else dp(46)
                    opacity: 0 if root.ads_hidden else 1
                    disabled: root.ads_hidden
                    on_press: root.buy_remove_ads()

                MinimalButton:
                    text: app.lbl_restore_purchases
                    btn_color: app.bg_elevated
                    text_color: app.text_secondary
                    font_size: "11sp"
                    size_hint_y: None
                    height: 0 if root.ads_hidden else dp(44)
                    opacity: 0 if root.ads_hidden else 1
                    disabled: root.ads_hidden
                    on_press: root.restore_purchases()

                # --- Divider ---
                Widget:
                    size_hint_y: None
                    height: dp(1)
                    canvas:
                        Color:
                            rgba: app.divider
                        Rectangle:
                            pos: self.pos
                            size: self.size

                # --- Cloud Save ---
                AutoShrinkLabel:
                    text: app.lbl_cloud_save
                    font_size: "13sp"
                    color: app.accent_cyan
                    halign: "left"
                    text_size: self.width, None
                    size_hint_y: None
                    height: dp(34)

                AutoShrinkLabel:
                    text: root.cloud_status
                    font_size: "11sp"
                    color: app.text_secondary
                    halign: "center"
                    text_size: self.width, None
                    size_hint_y: None
                    height: dp(34)

                MinimalButton:
                    text: root.google_btn_text if root.google_btn_text else app.lbl_sign_in_google
                    btn_color: app.accent_green if root.google_signed_in else app.accent_blue
                    font_size: "10sp" if root.google_signed_in else "12sp"
                    size_hint_y: None
                    height: dp(50)
                    on_press: root.cloud_sign_in()

                MinimalButton:
                    text: app.lbl_sign_out_google
                    btn_color: app.accent_red
                    font_size: "11sp"
                    size_hint_y: None
                    height: dp(48) if root.google_signed_in else 0
                    opacity: 1 if root.google_signed_in else 0
                    disabled: not root.google_signed_in
                    on_press: root.cloud_sign_out()

                MinimalButton:
                    text: app.lbl_save_to_cloud
                    btn_color: app.accent_green
                    text_color: app.bg_dark
                    font_size: "11sp"
                    size_hint_y: None
                    height: dp(50) if root.google_signed_in else 0
                    opacity: 1 if root.google_signed_in else 0
                    disabled: not root.google_signed_in
                    on_press: root.cloud_upload()

                MinimalButton:
                    text: app.lbl_load_from_cloud
                    btn_color: app.accent_purple
                    font_size: "11sp"
                    size_hint_y: None
                    height: dp(50) if root.google_signed_in else 0
                    opacity: 1 if root.google_signed_in else 0
                    disabled: not root.google_signed_in
                    on_press: root.cloud_download()

                # --- Divider ---
                Widget:
                    size_hint_y: None
                    height: dp(1)
                    canvas:
                        Color:
                            rgba: app.divider
                        Rectangle:
                            pos: self.pos
                            size: self.size

                # -- LEADERBOARD --
                AutoShrinkLabel:
                    text: app.lbl_leaderboard
                    font_size: "13sp"
                    color: app.accent_gold
                    halign: "left"
                    text_size: self.width, None
                    size_hint_y: None
                    height: dp(34)

                MinimalButton:
                    size_hint_y: None
                    height: dp(50)
                    text: app.lbl_view_leaderboard
                    btn_color: app.accent_gold
                    text_color: app.bg_dark
                    font_size: "11sp"
                    on_press: root.show_leaderboard()

                # --- Divider ---
                Widget:
                    size_hint_y: None
                    height: dp(1)
                    canvas:
                        Color:
                            rgba: app.divider
                        Rectangle:
                            pos: self.pos
                            size: self.size

                # --- Buy Diamonds ---
                AutoShrinkLabel:
                    text: app.lbl_buy_diamonds
                    font_size: "13sp"
                    color: app.accent_cyan
                    halign: "left"
                    text_size: self.width, None
                    size_hint_y: None
                    height: dp(34)

                GridLayout:
                    id: diamond_bundles_grid
                    cols: 1
                    spacing: 4
                    size_hint_y: None
                    height: self.minimum_height

                # --- Divider ---
                Widget:
                    size_hint_y: None
                    height: dp(1)
                    canvas:
                        Color:
                            rgba: app.divider
                        Rectangle:
                            pos: self.pos
                            size: self.size

                # --- Help ---
                MinimalButton:
                    size_hint_y: None
                    height: dp(50)
                    text: app.lbl_help
                    btn_color: app.accent_green
                    text_color: app.bg_dark
                    font_size: "11sp"
                    on_press: root.show_help()

                # --- Divider ---
                Widget:
                    size_hint_y: None
                    height: dp(1)
                    canvas:
                        Color:
                            rgba: app.divider
                        Rectangle:
                            pos: self.pos
                            size: self.size

                # --- Language ---
                AutoShrinkLabel:
                    text: app.lbl_language
                    font_size: "13sp"
                    color: app.accent_cyan
                    halign: "left"
                    text_size: self.width, None
                    size_hint_y: None
                    height: dp(34)

                MinimalButton:
                    size_hint_y: None
                    height: dp(50)
                    text: app.lbl_change_language
                    btn_color: app.accent_purple
                    font_size: "11sp"
                    on_press: root.show_language_picker()
